    {
      "parameters": {
        "jsCode": "const keywords = [\n  \"ai\",\n  \"artificial intelligence\",\n  \"llm\",\n  \"openai\",\n  \"anthropic\",\n  \"gemini\",\n  \"claude\",\n  \"agent\",\n  \"rag\",\n  \"machine learning\"\n];\n\nreturn items.filter(item => {\n  const title = (item.json.title || \"\").toLowerCase();\n\n  return keywords.some(k => title.includes(k));\n});"
      },
